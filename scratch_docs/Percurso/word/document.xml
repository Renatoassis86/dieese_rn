9181C" w:rsidRDefault="0009181C" w:rsidP="0009181C"><w:pPr><w:pStyle w:val="PargrafodaLista"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:spacing w:after="0" w:line="360" w:lineRule="auto"/><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr></w:pPr><w:r w:rsidRPr="007C0259"><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr><w:t>Se um indivíduo mudando já faz o mundo balançar, o que acontece quando um bloco inteiro, uma rua inteira ou um bairro inteiro decide mudar de atitude e exigir o que é seu por direito?</w:t></w:r></w:p><w:p w14:paraId="6527CD71" w14:textId="77777777" w:rsidR="0009181C" w:rsidRPr="007C0259" w:rsidRDefault="0009181C" w:rsidP="0009181C"><w:pPr><w:pStyle w:val="PargrafodaLista"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:spacing w:after="0" w:line="360" w:lineRule="auto"/><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr></w:pPr><w:r w:rsidRPr="007C0259"><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr><w:t>O sistema econômico atual muitas vezes lucra com o nosso cansaço. Quando estamos exaustos, sem tempo para "arrumar as gavetas" ou "ler um livro", perdemos a capacidade criativa de enxergar saídas.</w:t></w:r></w:p><w:p w14:paraId="43015991" w14:textId="77777777" w:rsidR="0009181C" w:rsidRPr="007C0259" w:rsidRDefault="0009181C" w:rsidP="0009181C"><w:pPr><w:pStyle w:val="PargrafodaLista"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr><w:spacing w:after="0" w:line="360" w:lineRule="auto"/><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr></w:pPr><w:r w:rsidRPr="007C0259"><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr><w:t xml:space="preserve">O autocuidado não é egoísmo; é </w:t></w:r><w:r w:rsidRPr="003959D5"><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr><w:t>processo necessário para nos manter de pé. Firmes e fortes. Se nós somos a principal força de mudança do território, precisamos estar inteiros para</w:t></w:r><w:r w:rsidRPr="007C0259"><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr><w:t xml:space="preserve"> conseguir sonhar e produzir e produzir.</w:t></w:r></w:p><w:p w14:paraId="25D5F0A3" w14:textId="77777777" w:rsidR="0009181C" w:rsidRPr="00CD31E7" w:rsidRDefault="0009181C" w:rsidP="0009181C"><w:pPr><w:spacing w:line="360" w:lineRule="auto"/><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>14h30</w:t></w:r><w:r w:rsidRPr="00CD31E7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> às </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>16</w:t></w:r><w:r w:rsidRPr="00CD31E7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>:</w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>0</w:t></w:r><w:r w:rsidRPr="00CD31E7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">0 </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>–</w:t></w:r><w:r w:rsidRPr="00CD31E7"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Apresentação das estatísticas do território </w:t></w:r></w:p><w:p w14:paraId="1B7D5257" w14:textId="77777777" w:rsidR="0009181C" w:rsidRDefault="0009181C" w:rsidP="0009181C"><w:pPr><w:spacing w:line="360" w:lineRule="auto"/><w:ind w:left="567"/><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>14:30</w:t></w:r><w:r w:rsidRPr="003B60E9"><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve"> às </w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>15</w:t></w:r><w:r w:rsidRPr="003B60E9"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>:</w:t></w:r><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t>10</w:t></w:r><w:r w:rsidRPr="00CD31E7"><w:t xml:space="preserve"> – </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="Garamond"/></w:rPr><w:t xml:space="preserve">Exposição dialogada de dados socioeconômicos do território </w:t></w:r><w:r w:rsidRPr="007D7AC3"><w:rPr><w:rFonts w:ascii="Garamond" w:hAnsi="